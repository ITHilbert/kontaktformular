{
    "name": "ithilbert/kontaktformular",
    "type": "library",
    "license": "MIT",
    "description": "Mein Kontaktformular mit Verarbeitungscode",
    "keywords": [
        "it-hilbert",
        "laravel",
        "homepage"
    ],
    "authors": [
        {
            "name": "Jörg Hilbert",
            "homepage": "https://www.it-hilbert.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://www.it-hilbert.com",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.5",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/mail": "^11.0 || ^12.0",
        "illuminate/routing": "^11.0 || ^12.0",
        "illuminate/console": "^11.0 || ^12.0",
        "ext-zip": "*"
    },
    "autoload": {
        "psr-4": {
            "ITHilbert\\Kontaktformular\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ITHilbert\\Kontaktformular\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ITHilbert\\Kontaktformular\\KontaktformularServiceProvider"
            ],
            "aliases": {}
        }
    }
}